# Copy to `.env` and fill in as needed. The app runs with ZERO changes here
# (mock LLM + bundled fixture data), so this file is only for opting into real providers.

# --- Database ---
# SQLite by default. To use Postgres later, change ONLY this line, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/trades
DATABASE_URL=sqlite:///./trades.db

# --- Data source: fixture | stock_watcher ---
TRADE_SOURCE=fixture

# --- LLM provider: mock | groq ---
LLM_PROVIDER=mock
# Get a free key at https://console.groq.com 
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
